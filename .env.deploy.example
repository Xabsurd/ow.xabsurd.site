DEPLOY_HOST=your.server.ip
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_PATH=/var/www/overwatch-workshop-hub
DEPLOY_APP_NAME=overwatch-workshop-hub
APP_PORT=3001

# Required. Initial backend/admin password. Also used by seed to create/update INITIAL_ADMIN_EMAIL.
SITE_PASSWORD=paste-admin-password-here

# Optional. If omitted, deploy.ts generates one for the deployed release.
# SESSION_SECRET=paste-session-secret-here

# Database.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=overwatch_workshop
DB_USER=overwatch_workshop
DB_PASSWORD=paste-db-password-here

# First admin account. Password comes from SITE_PASSWORD.
INITIAL_ADMIN_EMAIL=admin@example.com

# Optional when using SSH key auth:
# DEPLOY_SSH_KEY=C:\Users\you\.ssh\id_rsa

# Optional but recommended behind nginx:
# PUBLIC_BASE_URL=http://your-domain-or-ip

# Optional app env:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Overwatch Workshop <noreply@example.com>

# Optional:
# DEPLOY_BUILD_COMMAND=npm run build
# DEPLOY_INSTALL_COMMAND=npm install --ignore-scripts
