generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VerificationPurpose {
  REGISTER
  RESET_PASSWORD
}

enum CodeStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  DELETED
}

enum ReportStatus {
  OPEN
  RESOLVED
  REJECTED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  gameId       String         @unique
  passwordHash String
  role         UserRole       @default(USER)
  isBanned     Boolean        @default(false)
  banReason    String?
  bannedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     Session[]
  uploads      WorkshopCode[] @relation("Uploader")
  reviews      WorkshopCode[] @relation("Reviewer")
  favorites    Favorite[]
  reports      Report[]       @relation("Reporter")
  handled      Report[]       @relation("ReportHandler")
  auditLogs    AuditLog[]

  @@index([role])
  @@index([isBanned])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationCode {
  id        String              @id @default(cuid())
  email     String
  codeHash  String
  purpose   VerificationPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([email, purpose, createdAt])
}

model WorkshopCode {
  id             String            @id @default(cuid())
  workshopCode   String
  title          String
  description    String
  type           String
  difficulty     String
  mapName        String
  authorName     String?
  version        String?
  region         String?
  playerCount    String?
  language       String?
  status         CodeStatus         @default(PENDING)
  uploaderId     String
  uploader       User               @relation("Uploader", fields: [uploaderId], references: [id])
  reviewedById   String?
  reviewedBy     User?              @relation("Reviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewNote     String?
  viewCount      Int                @default(0)
  favoriteCount  Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  genjiPk        GenjiPkCode?
  parkour        ParkourCode?
  tags           WorkshopCodeTag[]
  favorites      Favorite[]
  reports        Report[]

  @@index([workshopCode])
  @@index([status])
  @@index([type])
  @@index([difficulty])
  @@index([mapName])
  @@index([createdAt])
}

model GenjiPkCode {
  id                String       @id @default(cuid())
  workshopCodeId    String       @unique
  workshopCode      WorkshopCode @relation(fields: [workshopCodeId], references: [id], onDelete: Cascade)
  levelCount        Int
  timerSupported    Boolean      @default(false)
  beginnerFriendly  Boolean      @default(false)
  averageClearTime  String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([levelCount])
}

model ParkourCode {
  id                String       @id @default(cuid())
  workshopCodeId    String       @unique
  workshopCode      WorkshopCode @relation(fields: [workshopCodeId], references: [id], onDelete: Cascade)
  hero              String
  levelCount        Int
  difficultyStart   String?
  timerSupported    Boolean      @default(false)
  beginnerFriendly  Boolean      @default(false)
  averageClearTime  String?
  source            String?
  sourceId          String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([hero])
  @@index([levelCount])
  @@index([difficultyStart])
  @@index([source])
  @@unique([source, sourceId])
}

model Tag {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  isHot     Boolean           @default(false)
  createdAt DateTime          @default(now())
  codes     WorkshopCodeTag[]
}

model MapOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  zhName    String?
  mode      String
  image     String?
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
  @@index([mode])
}

model WorkshopCodeTag {
  workshopCodeId String
  tagId          String
  workshopCode   WorkshopCode @relation(fields: [workshopCodeId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workshopCodeId, tagId])
}

model Favorite {
  id             String       @id @default(cuid())
  userId         String
  workshopCodeId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshopCode   WorkshopCode @relation(fields: [workshopCodeId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, workshopCodeId])
  @@index([workshopCodeId])
}

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  workshopCodeId String
  reason         String
  detail         String?
  status         ReportStatus @default(OPEN)
  handledById    String?
  handledAt      DateTime?
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  workshopCode   WorkshopCode @relation(fields: [workshopCodeId], references: [id], onDelete: Cascade)
  handledBy      User?        @relation("ReportHandler", fields: [handledById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([status])
  @@index([workshopCodeId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
